# ─── WhatsApp Baileys Server — Environment Variables ──────────────────────
# Copy this file to .env for local development, or set these in your
# Railway dashboard for production.
#
# How to get Supabase credentials:
#   Go to https://supabase.com → Project Settings → API
#
# ═══════════════════════════════════════════════════════════════════════════

# ── Required ──────────────────────────────────────────────────────────────

# Port for the server to listen on (Railway sets PORT automatically)
PORT=3001

# ── Optional (for DB persistence) ─────────────────────────────────────────
# If set, session metadata (status, phone number) is persisted to Supabase.
# The server works without these — QR auth and messaging work fine.
#
# Supabase project URL (e.g., https://xyz.supabase.co)
SUPABASE_URL=

# Supabase service role key (NOT the anon key)
# Found in: Project Settings → API → service_role key
SUPABASE_SERVICE_ROLE_KEY=

# ── CORS (optional) ───────────────────────────────────────────────────────
# Comma-separated list of allowed origins for CORS.
# Defaults to allowing all origins.
# Example: https://your-app.netlify.app,https://your-custom-domain.com
CORS_ORIGIN=
